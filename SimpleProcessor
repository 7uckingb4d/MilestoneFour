package smartparking;

public class SimpleProcessor implements PaymentProcessor {
    @Override
    public boolean processPayment(double amount) {
        System.out.println("Processing payment of: " + amount);
        return true;
    }

    @Override
    public String getPaymentMethodName() {
        return "Simple Processor";
    }

    @Override
    public void validatePaymentDetails() throws PaymentFrameworkException {
        // Simple validation - always passes
    }

    @Override
    public String generateReceipt() {
        return "Receipt generated by Simple Processor";
    }
}
